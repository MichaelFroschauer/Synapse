<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Simple "blinking" animation: 2s, alternate, infinite -->
    <Style Selector="Ellipse.blinking.green">
        <Setter Property="Fill" Value="#9fdcb5" />
        <Style.Animations>
            <Animation Duration="0:0:2" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0">
                    <Setter Property="Fill" Value="#9fdcb5" />
                </KeyFrame>
                <KeyFrame Cue="1">
                    <Setter Property="Fill" Value="#31ae5f" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Ellipse.blinking.black">
        <Setter Property="Fill" Value="#ffffff" />
        <Style.Animations>
            <Animation Duration="0:0:2" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0">
                    <Setter Property="Fill" Value="#ffffff" />
                </KeyFrame>
                <KeyFrame Cue="1">
                    <Setter Property="Fill" Value="#000000" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Subtle "focus" glow: changes opacity of a background border -->
    <Style Selector="Border.focus-glow">
        <Setter Property="Opacity" Value="0" />
        <Style.Animations>
            <Animation Duration="0:0:1.2" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
                <KeyFrame Cue="1">
                    <Setter Property="Opacity" Value="0.35" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Cursor blink (e.g. for input fields) -->
    <Style Selector="Rectangle.cursor-blink">
        <Setter Property="Width" Value="2" />
        <Setter Property="Opacity" Value="1" />
        <Style.Animations>
            <Animation Duration="0:0:1" IterationCount="Infinite" PlaybackDirection="Alternate">
                <KeyFrame Cue="0">
                    <Setter Property="Opacity" Value="1" />
                </KeyFrame>
                <KeyFrame Cue="1">
                    <Setter Property="Opacity" Value="0" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

</Styles>
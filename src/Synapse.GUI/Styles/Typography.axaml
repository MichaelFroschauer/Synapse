<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">
    <FontFamily x:Key="FontAwesome">avares://Synapse.GUI/Assets/Fonts/FontAwesome7Regular.otf#Font Awesome 7 Free Regular</FontFamily>
    <FontFamily x:Key="FontAwesomeSolid">avares://Synapse.GUI/Assets/Fonts/FontAwesome7Regular.otf#Font Awesome 7 Free Solid</FontFamily>
    
    <system:Double x:Key="FontSizeSmall">12</system:Double>
    <system:Double x:Key="FontSizeNormal">14</system:Double>
    <system:Double x:Key="FontSizeLarge">16</system:Double>
    <system:Double x:Key="FontSizeXL">20</system:Double>
    
</ResourceDictionary>
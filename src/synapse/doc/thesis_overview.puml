@startuml
' Synapse thesis-level overview (excluding Synapse.Test)
skinparam componentStyle rectangle
'skinparam shadowing false
'left to right direction
top to bottom direction

title Synapse - Thesis Component Overview

actor "User" as User

package "Synapse.GUI" {
  component "Avalonia UI\n(Views + ViewModels)" as Gui
}

package "Synapse.JobManagement" {
  interface "IJobManager" as IJobManager
  component "JobManager" as JobManager
  component "MetaheuristicAlgorithmFactory" as AlgoFactory

  IJobManager <|.. JobManager
}

package "Synapse.OptimizationCore" {
  interface "IMetaheuristic" as IMetaheuristic
  interface "IAlgorithmConfig" as IAlgorithmConfig
  interface "IAlgorithmController" as IAlgorithmController
  interface "IProblem" as IProblem
  interface "IFitnessEvaluator" as IFitnessEvaluator
  interface "ISolution" as ISolution
  interface "IHitlController" as IHitlController
}

package "Algorithm Implementations" {
  component "GA / NSGA-II / PSO / RAPGA" as AlgoImpl
  component "Algorithm Configs" as AlgoConfigs

  IMetaheuristic <|.. AlgoImpl
  IAlgorithmConfig <|.. AlgoConfigs
}

package "Problems (Synapse.Problems)" {
  component "TSP / QAP / JSP / Function" as Problems

  IProblem <|.. Problems
}

package "Synapse.HITL" {
  component "HitlController" as HitlController

  IHitlController <|.. HitlController
}

package "Synapse.HITL.Scripting" {
  interface "IScriptManager" as IScriptManager
  component "ScriptManager" as ScriptManager
  component "IScriptProvider + IApiClient\n(OpenRouter path)" as AiScriptPath

  IScriptManager <|.. ScriptManager
}

package "Synapse.Reflection" {
  interface "ITypeRegistry" as ITypeRegistry
  component "ReflectionRegistry" as ReflectionRegistry

  ITypeRegistry <|. ReflectionRegistry
}

JobManager -> AlgoFactory
JobManager -d-> IMetaheuristic : execute
JobManager -> IProblem : run on problem instance
JobManager -> IHitlController : pause/trigger/preferences

AlgoImpl -> IFitnessEvaluator : evaluate
AlgoImpl -> ISolution : evolve/update
HitlController -d-> IScriptManager : execute HITL scripts

User -> Gui
Gui -> IJobManager : submit/monitor jobs
Gui -> IHitlController : configure HITL
Gui -> IScriptManager : register scripts
Gui -d-> ITypeRegistry : discover pluggable types

Gui -[hidden]down-> IJobManager
IJobManager -[hidden]down-> IMetaheuristic
IMetaheuristic -[hidden]down-> AlgoImpl
AlgoImpl -[hidden]l-> Problems
Problems -[hidden]down-> HitlController
HitlController -[hidden]down-> ScriptManager
'ScriptManager -[hidden]down-> ReflectionRegistry

@enduml


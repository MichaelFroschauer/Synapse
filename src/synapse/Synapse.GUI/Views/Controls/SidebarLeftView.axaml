<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Synapse.GUI.Views.Controls"
             xmlns:vm1="clr-namespace:Synapse.GUI.ViewModels.Controls"
             x:Class="Synapse.GUI.Views.Controls.SidebarLeftView"
             x:DataType="vm1:SidebarLeftViewModel">

    <UserControl.Styles>
        <Style Selector="ToggleButton.sidebar-nav">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                            <Svg Path="{TemplateBinding Tag}" Width="20" Height="20" VerticalAlignment="Center" />
                            <ContentPresenter VerticalAlignment="Center" Content="{TemplateBinding Content}" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="ToggleButton.sidebar-nav:pointerover">
            <Setter Property="Background" Value="{DynamicResource SecondaryForegroundBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="ToggleButton.sidebar-nav:checked">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="Black" />
        </Style>

        <Style Selector="ToggleButton.sidebar-nav:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style Selector="TextBlock.sidebar-caption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="1.0" />
            <Setter Property="Margin" Value="4,8,0,0" />
        </Style>
    </UserControl.Styles>


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="6" Margin="12,12,12,3">
            <ToggleButton Classes="sidebar-nav"
                          Content="Algorithm Configuration"
                          Tag="/Assets/svg/parameters.svg"
                          Command="{Binding NavigateToAlgorithmCommand}"
                          IsChecked="{Binding IsAlgorithmSelected, Mode=TwoWay}"
                          ToolTip.Tip="Open Algorithm view"></ToggleButton>

            <ToggleButton Classes="sidebar-nav"
                          Tag="/Assets/svg/user_gear.svg"
                          Content="HITL"
                          Command="{Binding NavigateToHitlCommand}"
                          IsChecked="{Binding IsHitlSelected, Mode=TwoWay}"
                          ToolTip.Tip="Human-in-the-loop" />
            
            <ToggleButton Classes="sidebar-nav"
                          Tag="/Assets/svg/sourcefile.svg"
                          Content="HITL Scripting"
                          Command="{Binding NavigateToHitlScriptingCommand}"
                          IsChecked="{Binding IsHitlScriptingSelected, Mode=TwoWay}"
                          ToolTip.Tip="Human-in-the-loop Scripting" />

            <ToggleButton Classes="sidebar-nav"
                          Tag="/Assets/svg/chart.svg"
                          Content="Results"
                          Command="{Binding NavigateToResultsCommand}"
                          IsChecked="{Binding IsResultsSelected, Mode=TwoWay}"
                          ToolTip.Tip="View results and logs" />

            <ToggleButton Classes="sidebar-nav"
                          Tag="/Assets/svg/roboter.svg"
                          Content="AI"
                          Command="{Binding NavigateToAiCommand}"
                          IsChecked="{Binding IsAiSelected, Mode=TwoWay}"
                          ToolTip.Tip="AI configuration" />
        </StackPanel>

        <Separator Grid.Row="1" />

    </Grid>
</UserControl>